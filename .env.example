## ─── Core (Required) ────────────────────────────────────────────────
VITE_SUPABASE_URL=https://your-project-ref.supabase.co
VITE_SUPABASE_ANON_KEY=your-supabase-anon-or-publishable-key
VITE_SUPABASE_PROJECT_NAME=Confetti

## ─── AI Provider ────────────────────────────────────────────────────
# At least one required for AI chat:
OPENAI_API_KEY=sk-...
# ANTHROPIC_API_KEY=sk-ant-...

## ─── Payments (Stripe) ──────────────────────────────────────────────
# Free to create account; no charges until you process payments
STRIPE_SECRET_KEY=sk_test_...
VITE_STRIPE_PUBLISHABLE_KEY=pk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...

## ─── Nightlife/Dining (Yelp) ────────────────────────────────────────
# Free: 5,000 calls/day — https://www.yelp.com/developers/v3/manage_app
YELP_API_KEY=your-yelp-api-key

## ─── Place Intelligence (Google Places) ─────────────────────────────
# Used by scripts/fetch-place-intelligence.mjs and scripts/find-top-venues.mjs
GOOGLE_PLACES_API_KEY=your-google-places-api-key

## ─── Events (Ticketmaster) ──────────────────────────────────────────
# Free: 5,000 calls/day — https://developer.ticketmaster.com/
TICKETMASTER_API_KEY=your-ticketmaster-key

## ─── Push Notifications (Firebase) ──────────────────────────────────
# Free: unlimited — https://console.firebase.google.com
FIREBASE_PROJECT_ID=your-firebase-project
FIREBASE_CLIENT_EMAIL=firebase-adminsdk-xxxxx@your-project.iam.gserviceaccount.com
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"

## ─── SMS (Twilio) ───────────────────────────────────────────────────
# Pay-per-message ($0.0079/SMS) — https://www.twilio.com
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your-auth-token
TWILIO_PHONE_NUMBER=+1234567890

## ─── Email (SendGrid) ───────────────────────────────────────────────
# Free: 100 emails/day — https://sendgrid.com
SENDGRID_API_KEY=SG.xxxx
SENDGRID_FROM_EMAIL=hello@confetti.app

## ─── Wallet Passes ──────────────────────────────────────────────────
# Apple Wallet — requires Apple Developer account
APPLE_PASS_TYPE_ID=pass.com.confetti.boardingpass
APPLE_TEAM_ID=XXXXXXXXXX
APPLE_PASS_CERT_PATH=./certs/pass.p12
APPLE_PASS_CERT_PASSWORD=

# Google Wallet — https://pay.google.com/business/console
GOOGLE_WALLET_ISSUER_ID=1234567890
GOOGLE_WALLET_SERVICE_KEY=./certs/google-wallet-sa.json

## ─── No-Signup Services (always free, no keys needed) ───────────────
# Weather: Open-Meteo (free, no key) — used automatically
# Navigation: Google/Apple/Waze deep links — no key needed
# Rideshare: Uber/Lyft deep links — no key needed
# Analytics: Uses your existing Supabase project above

## ─── Edge Function Secrets (set via Supabase CLI) ───────────────────
# supabase secrets set TOMTOM_API_KEY=your-tomtom-key
# supabase secrets set OPENAI_API_KEY=sk-...
# supabase secrets set STRIPE_SECRET_KEY=sk_...
